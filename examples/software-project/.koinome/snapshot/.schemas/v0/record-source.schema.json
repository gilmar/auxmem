{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koinome.dev/schemas/v0/record-source.schema.json",
  "allOf": [
    { "$ref": "record-common.schema.json" },
    {
      "type": "object",
      "properties": {
        "type": { "const": "source" },
        "origin": { "type": "string", "minLength": 1 },
        "captured": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "required": ["type", "origin", "captured"]
    }
  ]
}
